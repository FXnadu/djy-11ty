{% extends "layouts/base.njk" %}

{% block content %}
<div class="post-layout">
  <article class="post">
    <header class="post-header">
      <h1>{{ title }}</h1>
      <time datetime="{{ date | dateISO }}">{{ date | dateFormat }}</time>
    </header>
    <div class="post-content">
      {{ content | safe }}
    </div>
  </article>
  <aside class="post-sidebar" aria-label="目录"></aside>
</div>
<script src="/assets/js/toc.js" defer></script>
<script src="/assets/js/footnote-preview.js" defer></script>
<script src="/assets/js/tabs.js" defer></script>
<script type="module">
  import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
  mermaid.initialize({ startOnLoad: true, theme: "base", themeVariables: { primaryColor: "#eaeae5", primaryTextColor: "#0a0a0a", primaryBorderColor: "#d0d0cb", lineColor: "#737373", fontFamily: "Inter, sans-serif" } });
</script>
{% endblock %}
