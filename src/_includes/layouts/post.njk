{% extends "layouts/base.njk" %}

{% block content %}
<div class="post-layout">
  <article class="post">
    <header class="post-header">
      <h1>{{ title }}</h1>
      <div class="post-meta">
        <time datetime="{{ date | dateISO }}">{{ date | dateFormat }}</time>
        {% if tags %}
        <div class="post-tags">
          {% for tag in tags %}
            {% if tag != "post" %}
              {% set tagUrl %}/gene/{{ tag | tagSlug }}/{% endset %}
              <a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </header>
    <div class="post-content">
      {{ content | safe }}
    </div>
  </article>
  <aside class="post-sidebar" aria-label="目录"></aside>
</div>
<script src="/assets/js/toc.js" defer></script>
<script src="/assets/js/footnote-preview.js" defer></script>
<script src="/assets/js/tabs.js" defer></script>
<script src="/assets/js/mermaid-loader.js" type="module"></script>
{% endblock %}
