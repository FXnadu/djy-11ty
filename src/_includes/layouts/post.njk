{% extends "layouts/base.njk" %}

{% block content %}
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ date | dateISO }}">{{ date | dateFormat }}</time>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
{% endblock %}
