{# Pagination with page selector popup
   Usage:
     {% set pgCurrent = 0 %}
     {% set pgTotal = 2 %}
     {% set pgBaseUrl = "/gene/生活/" %}
     {% include "partials/pagination.njk" %}
#}

{% if pgTotal > 1 %}
<nav class="pagination" aria-label="分页">
  {# Previous #}
  {% if pgCurrent > 0 %}
  <a href="{{ pgBaseUrl }}{% if pgCurrent > 1 %}{{ pgCurrent }}/{% endif %}" class="pagination-link">← 上一页</a>
  {% else %}
  <span class="pagination-link is-disabled">← 上一页</span>
  {% endif %}

  {# Page selector popup #}
  <div class="pagination-selector">
    <button class="pagination-selector-btn t-meta" aria-label="选择页码" aria-expanded="false">
      {{ pgCurrent + 1 }}/{{ pgTotal }}
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
    </button>
    <div class="pagination-popup" hidden>
      <div class="pagination-popup-grid">
        {% for i in range(pgTotal) %}
        <a href="{{ pgBaseUrl }}{% if i > 0 %}{{ i + 1 }}/{% endif %}" class="pagination-popup-page{% if i == pgCurrent %} is-current{% endif %}">{{ i + 1 }}</a>
        {% endfor %}
      </div>
    </div>
  </div>

  {# Next #}
  {% if pgCurrent < pgTotal - 1 %}
  <a href="{{ pgBaseUrl }}{{ pgCurrent + 2 }}/" class="pagination-link">下一页 →</a>
  {% else %}
  <span class="pagination-link is-disabled">下一页 →</span>
  {% endif %}
</nav>

<script src="/assets/js/pagination-popup.js" defer></script>
{% endif %}
