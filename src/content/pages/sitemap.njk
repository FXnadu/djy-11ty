---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ siteConfig.url }}/</loc>
    <lastmod>{{ "now" | dateISO }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ siteConfig.url }}/posts/</loc>
    <lastmod>{{ "now" | dateISO }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>{{ siteConfig.url }}/gene/</loc>
    <lastmod>{{ "now" | dateISO }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {% for post in collections.posts %}
  <url>
    <loc>{{ siteConfig.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | dateISO }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  {% endfor %}
  {% for pageData in collections.tagPages %}
  {% if pageData.page == 0 %}
  <url>
    <loc>{{ siteConfig.url }}/gene/{{ pageData.tag | tagSlug }}/</loc>
    <lastmod>{{ "now" | dateISO }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  {% endif %}
  {% endfor %}
  {% for pageData in collections.yearPages %}
  {% if pageData.page == 0 %}
  <url>
    <loc>{{ siteConfig.url }}/gene/{{ pageData.year }}/</loc>
    <lastmod>{{ "now" | dateISO }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  {% endif %}
  {% endfor %}
</urlset>
