---
title: 文章列表
permalink: /posts/
---

{% extends "layouts/base.njk" %}

{% block content %}
<h1 style="margin-top: var(--sp-10); margin-bottom: var(--sp-8);">{{ title }}</h1>
<ul class="post-list">
  {% for post in collections.posts %}
  <li>
    <span class="post-date">{{ post.date | dateFormat("yyyy-MM-dd") }}</span>
    <a href="{{ post.url }}" class="post-title">{{ post.data.title }}</a>
    <span class="post-category">{{ post.data.category or "随笔" }}</span>
  </li>
  {% endfor %}
</ul>
{% endblock %}
