---
title: 标签
permalink: /gene/
---

{% extends "layouts/base.njk" %}

{% block content %}
<div
  class="gene-header"
  data-tags-label="{{ collections.tagList | length }} 个标签"
  data-years-label="{{ collections.yearList | length }} 个年份"
>
  <h1 class="gene-title">
    <span class="gene-title-btn active" data-view="tags">标签</span>
    <span class="gene-title-sep">/</span>
    <span class="gene-title-btn" data-view="years">年份</span>
  </h1>
  <p class="gene-count t-meta" id="gene-count">{{ collections.tagList | length }} 个标签</p>
</div>

<div class="gene-view active" data-view="tags">
  <div class="tag-grid">
    {% for tag in collections.tagList %}
    {% set tagUrl %}/gene/{{ tag | tagSlug }}/{% endset %}
    {% set count = collections.tagCounts[tag] %}
    <a href="{{ tagUrl }}" class="tag-card">
      <span class="tag-name">{{ tag }}</span>
      <span class="tag-count t-meta">{{ count }} 篇</span>
    </a>
    {% endfor %}
  </div>
</div>

<div class="gene-view" data-view="years">
  <div class="tag-grid">
    {% for year in collections.yearList %}
    {% set yearPosts = collections.yearCollections.get(year) %}
    <a href="/gene/{{ year }}/" class="tag-card">
      <span class="tag-name tag-name-year">{{ year }}</span>
      <span class="tag-count t-meta">{{ yearPosts | length }} 篇</span>
    </a>
    {% endfor %}
  </div>
</div>

<script src="/assets/js/gene-toggle.js" defer></script>
{% endblock %}
