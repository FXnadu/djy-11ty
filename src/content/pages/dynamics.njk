---
title: 动态
permalink: /dynamics/
---

{% extends "layouts/base.njk" %}

{% block content %}
<h1 class="page-header">{{ title }}</h1>
<p class="lead">碎片想法、站点更新、日常记录。</p>

<div class="dynamics-feed">
  {% for item in collections.dynamics %}
  <article class="dynamics-item">
    <time class="dynamics-date t-meta" datetime="{{ item.date | dateFormat('yyyy-MM-dd') }}">{{ item.date | dateFormat("yyyy-MM-dd") }}</time>
    <div class="dynamics-body post-content">
      {{ item.templateContent | safe }}
    </div>
  </article>
  {% endfor %}
</div>
{% endblock %}
