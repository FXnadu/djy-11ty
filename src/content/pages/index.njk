---
title: 首页
permalink: /
---

{% extends "layouts/base.njk" %}

{% block content %}
<section class="hero">
  <p class="t-meta" style="margin-bottom: var(--sp-5);">DJY · 个人站点</p>
  <h1>{{ siteConfig.description }}</h1>
  <p class="lead">基于 Eleventy 构建的静态站点，记录技术笔记与个人思考。</p>
</section>

<hr class="hr-hairline">

<section class="section">
  <div class="section-header">
    <h2>最新文章</h2>
    <span class="t-meta">Recent</span>
  </div>
  <ul class="post-list">
    {% for post in collections.posts | limit(5) %}
    <li>
      <span class="post-date">{{ post.date | dateFormat("yyyy-MM-dd") }}</span>
      <a href="{{ post.url }}" class="post-title">{{ post.data.title }}</a>
      <span class="post-category">{{ post.data.category or "随笔" }}</span>
    </li>
    {% endfor %}
  </ul>
</section>
{% endblock %}
