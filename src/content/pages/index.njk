---
title: 首页
permalink: /
---

{% extends "layouts/base.njk" %}

{% block content %}
<section class="home-hero-split">
  <canvas class="ascii-bg" aria-hidden="true"></canvas>
  <div class="hero-content">
    <div class="split-left-content">
      <div class="t-meta" style="color: var(--grey-3); margin-bottom: var(--sp-7);">My Network Hub</div>
      <h2 style="font-family: var(--sans); font-weight: 200; font-size: min(8vw, 14vh); line-height: .94; letter-spacing: -.025em; color: var(--ink);">dengjunyu</h2>
      <p style="font-family: var(--sans); font-size: max(13px, 1vw); line-height: 1.6; color: var(--grey-3); font-weight: 300; max-width: 36ch; margin-top: var(--sp-6);">线上账号常有变动，这里是我稳定不变的网络中枢，你可在此查阅最新联系方式。</p>
    </div>

  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2>最新文章</h2>
    <span class="t-meta">Recent</span>
  </div>
  <ul class="post-list">
    {% for post in collections.posts | limit(3) %}
    <li>
      <span class="post-date">{{ post.date | dateFormat("yyyy-MM-dd") }}</span>
      <a href="{{ post.url }}" class="post-title">{{ post.data.title }}</a>
    </li>
    {% endfor %}
    <li>
      <span class="post-date"></span>
      <a href="/posts/" class="post-title">查看更多 →</a>
    </li>
  </ul>
</section>
{% endblock %}
